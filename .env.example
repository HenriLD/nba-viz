# Postgres connection string (Neon free tier: https://neon.tech)
# Format: postgresql+psycopg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.neon.tech/nba?sslmode=require

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Model slug — check https://openrouter.ai/models for current slugs and prices.
# Candidates to A/B with eval/run_eval.py:
#   moonshotai/kimi-k2
#   qwen/qwen-2.5-72b-instruct
#   mistralai/mistral-small-3.1-24b-instruct
OPENROUTER_MODEL=moonshotai/kimi-k2
